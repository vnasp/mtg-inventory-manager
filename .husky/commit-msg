#!/usr/bin/env sh

# Ensure PATH includes common node locations
export PATH="/usr/local/bin:/opt/homebrew/bin:$PATH"

# Get the commit message
commit_msg_file=$1
commit_msg=$(cat "$commit_msg_file")

# Conventional Commits regex pattern
# Matches: type(scope): description
# or: type(scope)!: description (breaking change)
# or: type: description
pattern='^(feat|fix|docs|style|refactor|perf|test|build|ci|chore|revert)(\(.+\))?(!)?: .{1,}'

# Check if commit message matches pattern
if ! echo "$commit_msg" | grep -qE "$pattern"; then
  echo ""
  echo "❌ ERROR: Commit message doesn't follow Conventional Commits format"
  echo ""
  echo "Expected format:"
  echo "  <type>(<scope>): <description>"
  echo ""
  echo "Types:"
  echo "  feat     - Nueva funcionalidad"
  echo "  fix      - Corrección de bug"
  echo "  docs     - Cambios en documentación"
  echo "  style    - Cambios de formato (espacios, etc.)"
  echo "  refactor - Refactorización de código"
  echo "  perf     - Mejoras de rendimiento"
  echo "  test     - Agregar o modificar tests"
  echo "  build    - Cambios en el sistema de build"
  echo "  ci       - Cambios en CI/CD"
  echo "  chore    - Tareas de mantenimiento"
  echo "  revert   - Revertir un commit anterior"
  echo ""
  echo "Examples:"
  echo "  feat(dashboard): add settings panel"
  echo "  fix(api): correct endpoint path"
  echo "  docs(readme): update installation guide"
  echo "  feat(config)!: change configuration schema"
  echo ""
  echo "Your message:"
  echo "  $commit_msg"
  echo ""
  exit 1
fi

# Check for merge commits
if echo "$commit_msg" | grep -qE '^Merge'; then
  exit 0
fi

# Check for revert commits
if echo "$commit_msg" | grep -qE '^Revert'; then
  exit 0
fi

exit 0
